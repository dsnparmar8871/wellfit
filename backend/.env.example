# Server
PORT=5000
HOST=0.0.0.0
# HOST=0.0.0.0 listens on all interfaces (required for VS Code port forwarding)
# Change to HOST=localhost for localhost-only access
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/wellfit?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_REGISTER_SECRET=set_a_strong_admin_registration_code

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SendGrid or Nodemailer SMTP)
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password_without_spaces
FROM_EMAIL=noreply@wellfit.com
FROM_NAME=Wellfit Menswear
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxx

# Frontend
CLIENT_URL=http://localhost:3000

# Loyalty
LOYALTY_POINTS_PER_RUPEE=1
LOYALTY_RUPEE_PER_POINT=0.5

# Low stock threshold
LOW_STOCK_THRESHOLD=5
